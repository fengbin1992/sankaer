FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o game ./cmd/game/

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /app/game /usr/local/bin/
COPY --from=builder /app/configs/game.yaml /etc/sankaer/game.yaml
EXPOSE 8081
CMD ["game", "-config", "/etc/sankaer/game.yaml"]
