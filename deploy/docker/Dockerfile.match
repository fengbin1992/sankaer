FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o match ./cmd/match/

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /app/match /usr/local/bin/
COPY --from=builder /app/configs/match.yaml /etc/sankaer/match.yaml
EXPOSE 8083
CMD ["match", "-config", "/etc/sankaer/match.yaml"]
