FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o gateway ./cmd/gateway/

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /app/gateway /usr/local/bin/
COPY --from=builder /app/configs/gateway.yaml /etc/sankaer/gateway.yaml
EXPOSE 8080
CMD ["gateway", "-config", "/etc/sankaer/gateway.yaml"]
