root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_style = tab
indent_size = 4

[*.{yaml,yml}]
indent_size = 2

[*.proto]
indent_size = 4

[*.{ts,js,json}]
indent_size = 4

[Makefile]
indent_style = tab
