{
    "compilerOptions": {
        "target": "ES2015",
        "module": "ES2015",
        "lib": ["ES2015", "DOM"],
        "strict": true,
        "esModuleInterop": true,
        "moduleResolution": "node",
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": "./assets/scripts",
        "declaration": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "assets/scripts/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "build",
        "temp",
        "library"
    ]
}
